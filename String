2-> Find All Substrings of a Given String 
    function allSubString(words){
        let result = [];
        for(let i=0; i < words.length; i++){
            for(let p=i+1; p <= words.length; p++){
                result.push(words.slice(i, p))
            }
        }
        return result;
    }
    
    console.log(allSubString('abcd'))

3-> Longest Substring Without Repeating Characters
      function lengthOfLongestSubstring(s) {
        let map = new Map();
        let left = 0;
        let maxLength = 0;
      
        for (let right = 0; right < s.length; right++) {
          let char = s[right];
      
          if (map.has(char) && map.get(char) >= left) {
            left = map.get(char) + 1;
          }
      
          map.set(char, right);
          maxLength = Math.max(maxLength, right - left + 1);
        }
      
        return maxLength;
      }
