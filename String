      function mostFrequentcharacter(words){
          const freq = {};
          let maxCount = 0;
          let maxChar = '';
          for(let word of words){
              freq[word] = (freq[word] || 0) + 1
              
              if(freq[word] > maxCount){
                  maxCount = freq[word]
                  maxChar = word
              }
          }
          console.log(freq)
          return maxChar
      }

